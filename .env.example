OPENAI_API_KEY=tu_api_key_de_openai_aqui
BLAZEDOCS_API_KEY=tu_api_key_de_blazedocs_aqui

# Encender el soporte para modelos locales
USE_LOCAL_LLM=true
# URL por defecto donde corre Ollama
LOCAL_LLM_URL=http://localhost:11434/v1

# Configuración híbrida (Qué tareas se van a local y cuáles a la nube)
USE_LOCAL_QA=true           # El QA conversacional usa el modelo local (Privacidad)
USE_LOCAL_EXPANSION=true    # Multi-Query/HyDE usa el modelo local (Ahorro de costos)
USE_LOCAL_EXTRACTION=false  # La extracción compleja de JSON sigue en GPT-4o (Precisión)
USE_LOCAL_JUDGE=false       # El juez de evaluaciones se queda en GPT-4o

# El nombre EXACTO del modelo que descargamos en Ollama (Local)
LLM_MODEL_QA=llama3.1:8b
LLM_MODEL_EXTRACTION=llama3.1:8b

# El nombre EXACTO del modelo a usar en la nube (OpenAI)
LLM_MODEL_QA_CLOUD=gpt-4o-mini
LLM_MODEL_EXTRACTION_CLOUD=gpt-4o
LLM_MODEL_JUDGE_CLOUD=gpt-4o
